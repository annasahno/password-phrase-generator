mixin intro()
  .intro
    //- вставлять блоки во внешний контейнер неверно
    //- все блоки содержат в себе container без доп класса tutorial__wrapper
    .container
      p(style="margin-top: 40px;") Текст&nbsp;с&nbsp;мнемониками

      p(style="margin-top: 40px;") Пример использования +img()
      p(style="margin-bottom: 40px;")
        +img("content", "placeholder", "png", 120, 120, "Пример")


div.software-card
  div.software-card__inner
    span.software-card__tag Тег карточки
    h2.software-card__heading Заголовок
  p.software-card__description Описание карточки с программным обеспечением
  a.software-card__btn.btn(href="#")
    svg(width="178", height="43", viewBox="0 0 178 43", fill="none", xmlns="http://www.w3.org/2000/svg")
    span.btn__text Подробнее


